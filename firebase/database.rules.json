{
  "rules": {
    "boats": {
      "iceCreamBoat": {
        "latest": {
          ".read": true,
          ".write": "auth != null && root.child('authorizedTrackers').child(auth.uid).val() === true",
          ".validate": "newData.hasChildren(['lat', 'lng', 'accuracy', 'timestamp', 'status', 'trackerUid'])",
          "lat": {
            ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90"
          },
          "lng": {
            ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180"
          },
          "accuracy": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000"
          },
          "altitude": {
            ".validate": "newData.isNumber()"
          },
          "heading": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 360"
          },
          "speed": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
          },
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() <= now + 60000"
          },
          "gpsTimestamp": {
            ".validate": "newData.isNumber()"
          },
          "updatedAtIso": {
            ".validate": "newData.isString() && newData.val().length <= 40"
          },
          "status": {
            ".validate": "newData.isString() && (newData.val() === 'tracking' || newData.val() === 'stopped')"
          },
          "trackerUid": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "authorizedTrackers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false,
        ".validate": "newData.isBoolean()"
      }
    }
  }
}

